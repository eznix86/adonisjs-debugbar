{
  "name": "@eznix/adonisjs-debugbar",
  "version": "0.1.0",
  "description": "Debug bar for AdonisJS",
  "keywords": [
    "adonisjs",
    "debugbar",
    "debug",
    "lucid",
    "inertia"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eznix86/adonisjs-debugbar.git"
  },
  "homepage": "https://github.com/eznix86/adonisjs-debugbar#readme",
  "bugs": {
    "url": "https://github.com/eznix86/adonisjs-debugbar/issues"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./provider": {
      "types": "./dist/src/provider.d.ts",
      "import": "./dist/src/provider.js"
    },
    "./middleware": {
      "types": "./dist/src/middleware.d.ts",
      "import": "./dist/src/middleware.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "import": "./dist/src/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp src/debugbar.html dist/src/ && cp src/debugbar.js dist/src/ && cp -r src/client dist/src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.0.0",
    "@adonisjs/lucid": "^21.0.0",
    "edge.js": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/lucid": {
      "optional": true
    },
    "edge.js": {
      "optional": true
    }
  }
}
