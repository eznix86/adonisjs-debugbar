{
  "name": "@eznix/adonisjs-debugbar",
  "version": "0.1.2",
  "description": "Debug bar for AdonisJS",
  "keywords": [
    "adonisjs",
    "debugbar",
    "debug",
    "lucid",
    "inertia"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eznix86/adonisjs-debugbar.git"
  },
  "homepage": "https://github.com/eznix86/adonisjs-debugbar#readme",
  "bugs": {
    "url": "https://github.com/eznix86/adonisjs-debugbar/issues"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./provider": {
      "types": "./dist/src/provider.d.ts",
      "import": "./dist/src/provider.js"
    },
    "./middleware": {
      "types": "./dist/src/middleware.d.ts",
      "import": "./dist/src/middleware.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "import": "./dist/src/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && mkdir -p dist/src && bunx tsc -p tsconfig.json && cp src/debugbar.html dist/src/ && cp src/debugbar.js dist/src/ && cp -r src/client dist/src/",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.6",
  "peerDependencies": {
    "@adonisjs/lucid": "^21.0.0",
    "edge.js": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/lucid": {
      "optional": true
    },
    "edge.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/lucid": "^21.0.0",
    "@types/node": "^25.3.5",
    "@vinejs/vine": "^4.3.0",
    "edge.js": "^6.0.0",
    "typescript": "^5.9.3"
  }
}
